<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvRegTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etRegName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Full Name"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRegRoll"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Roll Number"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRegBranch"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Branch (e.g. CS, IT)"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRegPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Set Password"
            android:inputType="textPassword"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnCaptureFace"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="📷 Capture Face"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnFinalRegister"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Register Now"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"/>

    </LinearLayout>
</ScrollView>